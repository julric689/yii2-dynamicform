{
    "name": "julric689/yii2-dynamicform",
    "description": "Widget to yii2 framework to clone form elements in a nested manner (fork of kidzen/yii2-dynamicform with relaxed Symfony constraints).",
    "keywords": [
        "yii2",
        "extension",
        "widget",
        "yii2-dynamicform"
    ],
    "type": "yii2-extension",
    "license": "BSD-3-Clause",
    "require": {
        "yiisoft/yii2": "~2.0.5",
        "symfony/css-selector": "~2.8|~3.0|~4.0|~5.0|~6.0|~7.0",
        "symfony/dom-crawler": "~2.8|~3.0|~4.0|~5.0|~6.0|~7.0"
    },
    "autoload": {
        "psr-4": {
            "kidzen\\dynamicform\\": "src"
        }
    }
}
